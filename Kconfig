menuconfig ZMK_INPUT_AMS_AS5600
	bool "AMS AS5600 angular position sensor for ZMK"
	default n
	depends on DT_HAS_ZMK_INPUT_AMS_AS5600_ENABLED
	select I2C
	select ZMK_POINTING
	help
	  Enable driver for ams AS5600 Angular position sensor as an input scroll device.

if ZMK_INPUT_AMS_AS5600

config ZMK_INPUT_AMS_AS5600_POLL_INTERVAL
	int "Legacy sample period between sensor reads in ms"
	default 20
	help
	  Legacy option kept for compatibility. New behavior uses
	  ZMK_INPUT_AMS_AS5600_ACTIVE_POLL_INTERVAL and
	  ZMK_INPUT_AMS_AS5600_IDLE_POLL_INTERVAL.

config ZMK_INPUT_AMS_AS5600_ACTIVE_POLL_INTERVAL
	int "Active polling interval in ms"
	default ZMK_INPUT_AMS_AS5600_POLL_INTERVAL
	range 1 1000
	help
	  Polling interval while movement is active.

config ZMK_INPUT_AMS_AS5600_IDLE_POLL_INTERVAL
	int "Idle polling interval in ms"
	default 500
	range 10 60000
	help
	  Polling interval while idling with the sensor power-gated off.

config ZMK_INPUT_AMS_AS5600_SENSOR_STARTUP_DELAY_MS
	int "Sensor startup delay in ms"
	default 2
	range 1 100
	help
	  Delay after powering the AS5600 before attempting I2C reads.

config ZMK_INPUT_AMS_AS5600_INACTIVITY_TIMEOUT_MS
	int "Inactivity timeout in ms"
	default 3000
	range 10 60000
	help
	  Time without movement before returning to idle mode and powering off the sensor.

config ZMK_INPUT_AMS_AS5600_MOVEMENT_THRESHOLD
	int "Movement threshold in raw counts"
	default 3
	range 1 2048
	help
	  Minimum absolute delta required to detect movement and emit scroll events.

config ZMK_INPUT_AMS_AS5600_SCROLL_SCALE_MULTIPLIER
	int "Scroll scaling multiplier"
	default 1
	range 1 64
	help
	  Numerator for scroll output scaling.

config ZMK_INPUT_AMS_AS5600_SCROLL_SCALE_DIVISOR
	int "Scroll scaling divisor"
	default 1
	range 1 64
	help
	  Denominator for scroll output scaling.

choice ZMK_INPUT_AMS_AS5600_POWER_MODE
	prompt "Power Mode"
	default ZMK_INPUT_AMS_AS5600_POWER_MODE_NOM

config ZMK_INPUT_AMS_AS5600_POWER_MODE_NOM
	bool "NOM: Always on"

config ZMK_INPUT_AMS_AS5600_POWER_MODE_LPM1
	bool "LPM1: Polling time = 5ms"

config ZMK_INPUT_AMS_AS5600_POWER_MODE_LPM2
	bool "LPM2: Polling time = 20ms"

config ZMK_INPUT_AMS_AS5600_POWER_MODE_LPM3
	bool "LPM3: Polling time = 100ms"

endchoice # ZMK_INPUT_AMS_AS5600_POWER_MODE

choice ZMK_INPUT_AMS_AS5600_HYSTERESIS
	prompt "Hysteresis"
	default ZMK_INPUT_AMS_AS5600_HYSTERESIS_OFF

config ZMK_INPUT_AMS_AS5600_HYSTERESIS_OFF
	bool "OFF"

config ZMK_INPUT_AMS_AS5600_HYSTERESIS_1LSB
	bool "1 LSB"

config ZMK_INPUT_AMS_AS5600_HYSTERESIS_2LSB
	bool "2 LSBs"

config ZMK_INPUT_AMS_AS5600_HYSTERESIS_3LSB
	bool "3 LSBs"

endchoice # ZMK_INPUT_AMS_AS5600_HYSTERESIS

choice ZMK_INPUT_AMS_AS5600_SLOW_FILTER
	prompt "Slow Filter"
	default ZMK_INPUT_AMS_AS5600_SLOW_FILTER_16X

config ZMK_INPUT_AMS_AS5600_SLOW_FILTER_16X
	bool "16x"

config ZMK_INPUT_AMS_AS5600_SLOW_FILTER_8X
	bool "8x"

config ZMK_INPUT_AMS_AS5600_SLOW_FILTER_4X
	bool "4x"

config ZMK_INPUT_AMS_AS5600_SLOW_FILTER_2X
	bool "2x"

endchoice # ZMK_INPUT_AMS_AS5600_SLOW_FILTER

choice ZMK_INPUT_AMS_AS5600_FAST_FILTER_THRESHOLD
	prompt "Fast Filter Threshold"
	default ZMK_INPUT_AMS_AS5600_FAST_FILTER_THRESHOLD_SLOW_ONLY

config ZMK_INPUT_AMS_AS5600_FAST_FILTER_THRESHOLD_SLOW_ONLY
	bool "Slow filter only"

config ZMK_INPUT_AMS_AS5600_FAST_FILTER_THRESHOLD_6LSB
	bool "6 LSBs"

config ZMK_INPUT_AMS_AS5600_FAST_FILTER_THRESHOLD_7LSB
	bool "7 LSBs"

config ZMK_INPUT_AMS_AS5600_FAST_FILTER_THRESHOLD_9LSB
	bool "9 LSBs"

config ZMK_INPUT_AMS_AS5600_FAST_FILTER_THRESHOLD_18LSB
	bool "18 LSBs"

config ZMK_INPUT_AMS_AS5600_FAST_FILTER_THRESHOLD_21LSB
	bool "21 LSBs"

config ZMK_INPUT_AMS_AS5600_FAST_FILTER_THRESHOLD_24LSB
	bool "24 LSBs"

config ZMK_INPUT_AMS_AS5600_FAST_FILTER_THRESHOLD_10LSB
	bool "10 LSBs"

endchoice # ZMK_INPUT_AMS_AS5600_FAST_FILTER_THRESHOLD

config ZMK_INPUT_AMS_AS5600_WATCHDOG_TIMER
	bool "Enable watchdog timer to allow saving power by switching into LMP3 if the angle stays within the watchdog threshold of 4 LSB for at least one minute"
	default n

config ZMK_INPUT_AMS_AS5600_STATUS_REGISTER_MONITORING
	bool "Check status register for errors"
	default y
	help
	  Enable checking the status register for errors AGC overflows, underflows or no magnet detected.

config ZMK_INPUT_AMS_AS5600_LOG_AGC
	bool "Print AGC value to console, to help with tuning the distance between the magnet and the sensor"
	default n

config ZMK_INPUT_AMS_AS5600_SET_HID_RESOLUTION_MULTIPLIER
	bool "Set wheel HID resolution multiplier"
	default y
	depends on ZMK_POINTING_SMOOTH_SCROLLING
	help
	  Force the current endpoint wheel resolution multiplier (HID usage 0x48)
	  to a fixed value before reporting wheel input. This can improve smooth
	  scrolling behavior over BLE on firmware versions where BLE multiplier
	  synchronization is unreliable.

config ZMK_INPUT_AMS_AS5600_HID_WHEEL_RESOLUTION
	int "Wheel HID resolution multiplier value"
	range 0 15
	default 15
	depends on ZMK_INPUT_AMS_AS5600_SET_HID_RESOLUTION_MULTIPLIER
	help
	  Wheel HID resolution multiplier used when
	  ZMK_INPUT_AMS_AS5600_SET_HID_RESOLUTION_MULTIPLIER is enabled.

config ZMK_INPUT_AMS_AS5600_INIT_PRIORITY
	int "Drivers init priority"
	default 90

endif # ZMK_INPUT_AMS_AS5600
